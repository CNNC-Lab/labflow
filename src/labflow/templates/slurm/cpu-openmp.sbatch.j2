#!/bin/bash
#SBATCH --job-name={{ job_name }}
#SBATCH --account={{ account }}
#SBATCH --partition={{ partition }}
#SBATCH --time={{ walltime }}
#SBATCH --nodes={{ nodes }}
#SBATCH --ntasks=1
#SBATCH --cpus-per-task={{ cpus_per_task }}
#SBATCH --mem={{ mem }}
{% if exclusive %}#SBATCH --exclusive{% endif %}
#SBATCH --output={{ output_dir }}/stdout.log
#SBATCH --error={{ output_dir }}/stderr.log

mkdir -p {{ output_dir }}
cd {{ project_scratch }}

{% for module in modules %}
module load {{ module }}
{% endfor %}
{% if eessi %}
source {{ eessi_init }}
{% endif %}

export OMP_NUM_THREADS={{ cpus_per_task }}
export OMP_PROC_BIND=TRUE

{% if container %}
singularity exec {{ container }} python {{ entry_point }}
{% else %}
python {{ entry_point }}
{% endif %}
